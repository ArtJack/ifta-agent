# Copy this file to .env and fill in your real key.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_KEY

# Telegram intake bot. Create this with @BotFather in Telegram.
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOTFATHER_TOKEN

# Optional: Eugene/admin Telegram numeric IDs, comma-separated.
# Users can send /id to the bot to see their numeric ID.
TELEGRAM_ADMIN_USER_IDS=

# Optional bot settings.
TELEGRAM_MAX_FILE_MB=20
TELEGRAM_AGENT_MODEL=claude-opus-4-7
TELEGRAM_AGENT_EFFORT=medium
TELEGRAM_AGENT_MAX_TOKENS=4096
TELEGRAM_SKIP_AGENT=0

# Web intake (FastAPI). All optional — defaults work for local dev.
# IFTA_WEB_DB_PATH=data/web_jobs.db
# IFTA_WEB_SUBMISSIONS_DIR=data/web_submissions
# IFTA_WEB_CORS_ORIGINS=https://artjeck.com,http://localhost:3000
# IFTA_WEB_MAX_FILE_MB=10
# Resend (for confirmation + packet emails — added in a later phase).
# RESEND_API_KEY=REPLACE_WITH_RESEND_KEY
# RESEND_FROM_EMAIL=ifta@artjeck.com
# IFTA_WEB_PUBLIC_BASE_URL=https://artjeck.com
