<?xml version="1.0" encoding="UTF-8"?>
<!--
  IFTA data backup. Run by launchd once a day; snapshots data/ to the AI-lab
  share (or $IFTA_BACKUP_DIR) and prunes old snapshots. Install with
  deploy/install.sh (substitutes __PROJECT_ROOT__).

  This is a one-shot job (not KeepAlive). Logs land in
  __PROJECT_ROOT__/logs/backup.{out,err}.log.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.artjeck.ifta-backup</string>

    <key>WorkingDirectory</key>
    <string>__PROJECT_ROOT__</string>

    <key>ProgramArguments</key>
    <array>
        <string>__PROJECT_ROOT__/.venv/bin/ifta</string>
        <string>backup</string>
    </array>

    <!-- Daily at 03:30 local. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>3</integer>
        <key>Minute</key>
        <integer>30</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>__PROJECT_ROOT__/logs/backup.out.log</string>

    <key>StandardErrorPath</key>
    <string>__PROJECT_ROOT__/logs/backup.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
